# Mode: dev (Neon multi-schema) | prod (FDW analytics_db)
ANALYTICS_MODE=dev

# Dev — Neon connection (5 schemas in 1 DB)
NEON_DB_HOST=ep-xxx.region.aws.neon.tech
NEON_DB_PORT=5432
NEON_DB_NAME=neondb
NEON_DB_USER=neondb_owner
NEON_DB_PASSWORD=
NEON_DB_SSLMODE=require

# Prod — central analytics_db (with postgres_fdw to 5 service DBs)
ANALYTICS_DB_HOST=
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=analytics_db
ANALYTICS_DB_USER=
ANALYTICS_DB_PASSWORD=
ANALYTICS_DB_SSLMODE=require

# Groq LLM (free tier — get key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_RATE_LIMIT_SLEEP=2.5
