# Mode: dev (Neon multi-schema, shared with running app)
#     | eval (isolated Neon branch with ~25k Faker rows for Phase 3 eval)
#     | prod (FDW analytics_db)
ANALYTICS_MODE=dev

# Dev — Neon connection (5 schemas in 1 DB; this is the LIVE app DB — never seed/truncate it)
NEON_DB_HOST=ep-xxx.region.aws.neon.tech
NEON_DB_PORT=5432
NEON_DB_NAME=neondb
NEON_DB_USER=neondb_owner
NEON_DB_PASSWORD=
NEON_DB_SSLMODE=require

# Eval — dedicated Neon branch for Phase 3 dataset/eval. Faker-seeded (~25k rows),
# safe to TRUNCATE. Create via Neon console "Branches" → branch off main, then paste
# the branch connection string here and run with ANALYTICS_MODE=eval.
EVAL_DB_HOST=
EVAL_DB_PORT=5432
EVAL_DB_NAME=neondb
EVAL_DB_USER=neondb_owner
EVAL_DB_PASSWORD=
EVAL_DB_SSLMODE=require

# Dev — restricted role for ORG-scoped Text2SQL (see scripts/setup_org_rls.sql)
# Same host/db as above; only reads the org_analytics.* views.
NEON_DB_ORG_USER=analytics_org_ro
NEON_DB_ORG_PASSWORD=

# JWT — public key (PEM) to verify tokens. Optional in dev: if unset, the
# gateway is trusted and claims are read without signature verification.
JWT_PUBLIC_KEY_PATH=

# Optional: route LLM to any OpenAI-compatible endpoint (Together/SambaNova/...).
# Unset → native Groq. GROQ_API_KEY holds whatever provider's key.
LLM_BASE_URL=

# Prod — central analytics_db (with postgres_fdw to 5 service DBs)
ANALYTICS_DB_HOST=
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=analytics_db
ANALYTICS_DB_USER=
ANALYTICS_DB_PASSWORD=
ANALYTICS_DB_SSLMODE=require
ANALYTICS_DB_ORG_USER=analytics_org_ro
ANALYTICS_DB_ORG_PASSWORD=

# Groq LLM (free tier — get key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Fast/small model for entity extraction (classification-only, no SQL).
# Groq: llama-3.1-8b-instant | Together AI: meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
LLM_FAST_MODEL=llama-3.1-8b-instant
# Uncomment when running batch eval to stay under Groq free-tier 30 RPM.
# LLM_RATE_LIMIT_SLEEP=2.5
