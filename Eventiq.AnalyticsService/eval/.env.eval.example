# Copy this to .env before running the eval
# Place Spider dataset in eval/data/spider/

# Together AI credentials (use GROQ_API_KEY slot for auth header)
GROQ_API_KEY=your_together_api_key_here
LLM_BASE_URL=https://api.together.xyz/v1

# Throttle: 60 RPM → 1.0 s between LLM calls
LLM_RATE_LIMIT_SLEEP=1.0

# Model (Together AI)
EVAL_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Optional limits
EVAL_MAX_QUESTIONS=0          # 0 = all 1034; set e.g. 50 for a smoke test
EVAL_SKIP_ENTITY_LLM=0        # 1 = skip entity extraction LLM, use keyword matching only
EVAL_CONFIDENCE_THRESHOLD=0.7
