{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "PublicKeyPath": "keys/public.key"
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": ""
  },
  "Reconciliation": {
    "IntervalSeconds": 120,
    "GraceMinutes": 15,
    "LookbackHours": 24,
    "BatchSize": 50
  },
  "InternalServices": {
    "EventServiceBaseUrl": "http://localhost:5232",
    "SeatServiceBaseUrl": "http://localhost:5234",
    "OrgServiceBaseUrl": "http://localhost:5230"
  }
}
